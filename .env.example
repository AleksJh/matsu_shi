# ============================================================
# Matsu Shi — Environment Variables
# Copy this file to .env and fill in all values before running
# ============================================================

# ------------------------------------------------------------------
# Telegram
# ------------------------------------------------------------------
BOT_TOKEN=                        # BotFather token (e.g. 123456:ABC-DEF...)
ADMIN_TELEGRAM_ID=                # Your personal Telegram user_id (integer)

# ------------------------------------------------------------------
# Google AI Studio
# ------------------------------------------------------------------
GEMINI_API_KEY=                   # Google AI Studio API key
LLM_LITE_MODEL=gemini-2.5-flash-lite
LLM_ADVANCED_MODEL=gemini-3-flash-preview

# ------------------------------------------------------------------
# OpenRouter (embeddings via qwen3-embedding-4b)
# ------------------------------------------------------------------
OPENROUTER_API_KEY=               # OpenRouter API key
EMBED_MODEL=qwen3-embedding-4b

# ------------------------------------------------------------------
# Jina AI (reranking)
# ------------------------------------------------------------------
JINA_API_KEY=                     # Jina AI API key
RERANKER_MODEL=jina-reranker-v3

# ------------------------------------------------------------------
# Cloudflare R2 (image storage)
# ------------------------------------------------------------------
CF_R2_ENDPOINT=                   # https://<account_id>.r2.cloudflarestorage.com
CF_R2_ACCESS_KEY_ID=              # R2 API token access key
CF_R2_SECRET_ACCESS_KEY=          # R2 API token secret key
CF_R2_BUCKET=matsu-shi-images     # R2 bucket name
CF_R2_PUBLIC_BASE_URL=            # Public read base URL for R2 bucket

# ------------------------------------------------------------------
# Langfuse (observability)
# ------------------------------------------------------------------
LANGFUSE_PUBLIC_KEY=              # Langfuse project public key
LANGFUSE_SECRET_KEY=              # Langfuse project secret key
LANGFUSE_HOST=https://cloud.langfuse.com

# ------------------------------------------------------------------
# Database (PostgreSQL with pgvector)
# ------------------------------------------------------------------
POSTGRES_USER=postgres                # PostgreSQL superuser name
POSTGRES_PASSWORD=postgres            # PostgreSQL superuser password (change in prod!)
POSTGRES_DB=matsu_shi                 # PostgreSQL database name
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/matsu_shi

# ------------------------------------------------------------------
# Redis (rate limiting + caching)
# ------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# ------------------------------------------------------------------
# Security
# ------------------------------------------------------------------
SECRET_KEY=                       # openssl rand -hex 32
# Admin user created via script (not env vars):
#   python backend/scripts/create_admin.py --username admin --password <secret>

# ------------------------------------------------------------------
# Application
# ------------------------------------------------------------------
APP_BASE_URL=https://yourdomain.com
ENVIRONMENT=development           # development | production

# ------------------------------------------------------------------
# RAG Thresholds
# ------------------------------------------------------------------
RETRIEVAL_SCORE_THRESHOLD=0.65
RETRIEVAL_NO_ANSWER_THRESHOLD=0.30

# ------------------------------------------------------------------
# Embedding dimension (pgvector HNSW max = 2000; qwen3-embedding-4b supports MRL truncation)
# Confirm actual output dim from first OpenRouter call before applying migration
# ------------------------------------------------------------------
EMBED_DIM=1024

# ------------------------------------------------------------------
# Chunking — text chunks smaller than this are merged into the preceding chunk
# Increase if too many tiny subsection chunks appear in the DB
# ------------------------------------------------------------------
CHUNK_MIN_TOKENS=80
